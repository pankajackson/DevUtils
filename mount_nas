#!/usr/bin/env bash

CONFIG_FILE="$HOME/.config/syno-cli/config"
MOUNT_BASE="$HOME/NAS"
SESSION_PASS=""

mkdir -p "$MOUNT_BASE"
mkdir -p "$(dirname "$CONFIG_FILE")"
touch "$CONFIG_FILE"

# --------------------------
# Read config
# --------------------------
get_config() {
  local profile="$1"
  local key="$2"

  awk -F '=' -v section="[$profile]" -v key="$key" '
    $0 == section { found=1; next }
    /^\[/ { found=0 }
    found && $1 == key { print $2; exit }
  ' "$CONFIG_FILE"
}

# --------------------------
# List profiles
# --------------------------
list_profiles() {
  grep "^\[" "$CONFIG_FILE" | tr -d '[]'
}

# --------------------------
# Clean input
# --------------------------
clean_input() {
  local val="$1"
  val="$(printf "%s" "$val" | tr -d '\r\n')"
  val="${val#"${val%%[![:space:]]*}"}"
  val="${val%"${val##*[![:space:]]}"}"
  echo -n "$val"
}

# --------------------------
# Prompt helper
# --------------------------
prompt() {
  local text="$1"
  local secret="$2"
  local val

  if [ "$secret" = "true" ]; then
    read -s -p "$text: " val
    echo
  else
    read -p "$text: " val
  fi

  clean_input "$val"
}

# --------------------------
# Check mount
# --------------------------
is_mounted() {
  mount | grep -q "on $1 "
}

# --------------------------
# Resolve credentials
# --------------------------
resolve_pass() {
  local profile="$1"
  local cli_pass="$2"

  # 1. CLI
  if [ -n "$cli_pass" ]; then
    pass="$cli_pass"
    return
  fi

  # 2. SESSION
  if [ -n "$SESSION_PASS" ]; then
    pass="$SESSION_PASS"
    return
  fi

  # 3. profile
  local cfg_pass
  cfg_pass=$(get_config "$profile" "pass")

  if [ -n "$cfg_pass" ]; then
    pass="$cfg_pass"
    return
  fi

  # 4. prompt ONCE
  SESSION_PASS=$(prompt "Enter password" true)
  pass="$SESSION_PASS"
}

# --------------------------
# Mount single share
# --------------------------
mount_nas() {
  local share="$1"
  shift

  local host=""
  local user=""
  local pass=""
  local domain=""
  local profile="default"

  # ---- parse args ----
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -H|--host) host="$2"; shift 2 ;;
      -U|--username) user="$2"; shift 2 ;;
      -P|--password) pass="$2"; shift 2 ;;
      -D|--domain) domain="$2"; shift 2 ;;
      -p|--profile) profile="$2"; shift 2 ;;
      *) echo "❌ Unknown option: $1"; return 1 ;;
    esac
  done

  local mount_point="$MOUNT_BASE/$share"
  mkdir -p "$mount_point"

  if is_mounted "$mount_point"; then
    echo "⚠️  $share already mounted"
    return 0
  fi

  # ---- config fallback (except pass) ----
  [ -z "$host" ] && host=$(get_config "$profile" "host")
  [ -z "$user" ] && user=$(get_config "$profile" "user")
  [ -z "$domain" ] && domain=$(get_config "$profile" "domain")
  [ -z "$domain" ] && domain="WORKGROUP"

  # ---- resolve password (correct priority) ----
  resolve_pass "$profile" "$pass"

  # ---- prompt fallback ----
  [ -z "$host" ] && host=$(prompt "Enter NAS host/IP")
  [ -z "$user" ] && user=$(prompt "Enter username")

  if [ -z "$host" ] || [ -z "$user" ]; then
    echo "❌ Missing required connection details"
    return 1
  fi

  # ---- mount all fallback ----
  if [ -z "$share" ]; then
    mount_all -p "$profile"
    return
  fi

  # ---- credentials file ----
  cred=$(mktemp)
  chmod 600 "$cred"

  pass_clean=$(clean_input "$pass")

  printf "username=%s\npassword=%s\ndomain=%s\n" \
    "$user" "$pass_clean" "$domain" > "$cred"

  # ---- mount ----
  sudo mount -t cifs "//$host/$share" "$mount_point" \
    -o credentials="$cred",vers=3.0,sec=ntlmssp,uid=$(id -u),gid=$(id -g),iocharset=utf8,file_mode=0775,dir_mode=0775

  status=$?
  rm -f "$cred"

  if [ $status -eq 0 ]; then
    echo "✅ Mounted $share → $mount_point"
  else
    echo "❌ Failed to mount //$host/$share"
    echo "👉 Debug: sudo dmesg | tail -n 20"
    return 1
  fi
}

# --------------------------
# Mount all
# --------------------------
mount_all() {
  local profile="default"
  local extra_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p|--profile)
        profile="$2"
        extra_args+=("$1" "$2")
        shift 2
        ;;
      *)
        extra_args+=("$1")
        shift
        ;;
    esac
  done

  shares=$(get_config "$profile" "shares")

  if [ -z "$shares" ]; then
    echo "❌ No shares defined in profile '$profile'"
    return 1
  fi

  IFS=',' read -ra list <<< "$shares"

  for s in "${list[@]}"; do
    mount_nas "$s" "${extra_args[@]}"
  done
}

# --------------------------
# Unmount single share
# --------------------------
unmount_nas() {
  local share="$1"
  local mount_point="$MOUNT_BASE/$share"

  if ! is_mounted "$mount_point"; then
    echo "⚠️  $share is not mounted"
    return 0
  fi

  sudo umount "$mount_point"

  if [ $? -eq 0 ]; then
    echo "🗑️ Unmounted $share"
  else
    echo "❌ Failed to unmount $share"
  fi
}

# --------------------------
# Unmount all
# --------------------------
unmount_all() {
  local profile="default"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -p|--profile) profile="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  shares=$(get_config "$profile" "shares")

  [ -z "$shares" ] && {
    echo "❌ No shares defined in profile '$profile'"
    return 1
  }

  IFS=',' read -ra list <<< "$shares"

  for s in "${list[@]}"; do
    unmount_nas "$s"
  done
}

# --------------------------
# Config command
# --------------------------
config_profile() {
  read -p "Profile name: " profile
  read -p "Host: " host
  read -p "Username: " user
  read -s -p "Password: " pass
  echo
  read -p "Domain [WORKGROUP]: " domain
  read -p "Shares (comma separated): " shares

  [ -z "$domain" ] && domain="WORKGROUP"

  sed -i "/^\[$profile\]/,/^\[/d" "$CONFIG_FILE"

  cat >> "$CONFIG_FILE" <<EOF
[$profile]
host=$host
user=$user
pass=$pass
domain=$domain
shares=$shares
EOF

  chmod 600 "$CONFIG_FILE"
  echo "✅ Profile saved"
}

# --------------------------
# Entry
# --------------------------
action="$1"
shift

if [[ "$action" == -* ]]; then
  action="${action#-}"
  mode="unmount"
else
  mode="mount"
fi

case "$action" in
  all)
    if [ "$mode" = "mount" ]; then
      mount_all "$@"
    else
      unmount_all "$@"
    fi
    ;;
  config)
    config_profile
    ;;
  list)
    list_profiles
    ;;
  *)
    if [ "$mode" = "mount" ]; then
      mount_nas "$action" "$@"
    else
      unmount_nas "$action"
    fi
    ;;
esac