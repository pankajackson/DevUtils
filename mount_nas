#!/usr/bin/env bash

CONFIG_FILE="$HOME/.config/syno-cli/config"
MOUNT_BASE="$HOME/NAS"

mkdir -p "$MOUNT_BASE"
mkdir -p "$(dirname "$CONFIG_FILE")"
touch "$CONFIG_FILE"

# --------------------------
# Read config
# --------------------------
get_config() {
  local profile="$1"
  local key="$2"

  awk -F '=' -v section="[$profile]" -v key="$key" '
    $0 == section { found=1; next }
    /^\[/ { found=0 }
    found && $1 == key { print $2; exit }
  ' "$CONFIG_FILE"
}

# --------------------------
# List profiles
# --------------------------
list_profiles() {
  grep "^\[" "$CONFIG_FILE" | tr -d '[]'
}

# --------------------------
# Clean input (CR/LF + trim)
# --------------------------
clean_input() {
  local val="$1"

  # remove CR/LF
  val="$(printf "%s" "$val" | tr -d '\r\n')"

  # trim spaces
  val="${val#"${val%%[![:space:]]*}"}"
  val="${val%"${val##*[![:space:]]}"}"

  echo -n "$val"
}

# --------------------------
# Prompt helper (safe)
# --------------------------
prompt() {
  local text="$1"
  local secret="$2"
  local val

  if [ "$secret" = "true" ]; then
    read -s -p "$text: " val
    echo
  else
    read -p "$text: " val
  fi

  clean_input "$val"
}

# --------------------------
# Check mount
# --------------------------
is_mounted() {
  mount | grep -q "on $1 "
}

# --------------------------
# Save profile
# --------------------------
save_profile() {
  echo
  read -p "💾 Save these credentials as profile? (y/n): " ans
  [[ "$ans" != "y" ]] && return

  echo
  echo "Existing profiles:"
  list_profiles
  echo

  read -p "Enter profile name: " profile

  if grep -q "^\[$profile\]" "$CONFIG_FILE"; then
    read -p "⚠️ Profile exists. Overwrite? (y/n): " overwrite
    [[ "$overwrite" != "y" ]] && return
    sed -i "/^\[$profile\]/,/^\[/d" "$CONFIG_FILE"
  fi

  [ -z "$shares" ] && shares="Media,Games,Workspace,Software,Personal,Archive"

  cat >> "$CONFIG_FILE" <<EOF
[$profile]
host=$host
user=$user
pass=$pass
domain=$domain
shares=$shares
EOF

  chmod 600 "$CONFIG_FILE"

  echo "✅ Profile '$profile' saved"
}

# --------------------------
# Mount single share
# --------------------------
mount_nas() {
  local share="$1"
  shift

  local host=""
  local user=""
  local pass=""
  local domain=""
  local profile="default"

  # ---- parse args ----
  while [[ $# -gt 0 ]]; do
    case "$1" in
      -H|--host) host="$2"; shift 2 ;;
      -U|--username) user="$2"; shift 2 ;;
      -P|--password) pass="$2"; shift 2 ;;
      -D|--domain) domain="$2"; shift 2 ;;
      --profile) profile="$2"; shift 2 ;;
      *) echo "❌ Unknown option: $1"; return 1 ;;
    esac
  done

  # ---- fallback config ----
  [ -z "$host" ] && host=$(get_config "$profile" "host")
  [ -z "$user" ] && user=$(get_config "$profile" "user")
  [ -z "$pass" ] && pass=$(get_config "$profile" "pass")
  [ -z "$domain" ] && domain=$(get_config "$profile" "domain")

  # ---- defaults ----
  [ -z "$domain" ] && domain="WORKGROUP"

  # ---- prompt ----
  [ -z "$host" ] && host=$(prompt "Enter NAS host/IP")
  [ -z "$user" ] && user=$(prompt "Enter username")
  [ -z "$pass" ] && pass=$(prompt "Enter password" true)

  if [ -z "$host" ] || [ -z "$user" ]; then
    echo "❌ Missing required connection details"
    return 1
  fi

  # ---- no share → mount all ----
  if [ -z "$share" ]; then
    echo "⚠️ No share provided → mounting all from profile"
    mount_all --profile "$profile"
    return
  fi

  # ---- offer save ----
  if [ -z "$(get_config "$profile" "host")" ]; then
    shares="$share"
    save_profile
  fi

  local mount_point="$MOUNT_BASE/$share"
  mkdir -p "$mount_point"

  if is_mounted "$mount_point"; then
    echo "⚠️  $share already mounted"
    return 0
  fi

  # ---- credentials file ----
  cred=$(mktemp)
  chmod 600 "$cred"

  pass_clean=$(clean_input "$pass")

  printf "username=%s\npassword=%s\ndomain=%s\n" \
    "$user" "$pass_clean" "$domain" > "$cred"

  # ---- mount ----
  sudo mount -t cifs "//$host/$share" "$mount_point" \
    -o credentials="$cred",vers=3.0,sec=ntlmssp,uid=$(id -u),gid=$(id -g),iocharset=utf8,file_mode=0775,dir_mode=0775

  status=$?
  rm -f "$cred"

  if [ $status -eq 0 ]; then
    echo "✅ Mounted $share → $mount_point"
  else
    echo "❌ Failed to mount //$host/$share"
    echo "👉 Debug: sudo dmesg | tail -n 20"
    return 1
  fi
}

# --------------------------
# Mount all
# --------------------------
mount_all() {
  local profile="default"

  if [ "$1" = "--profile" ]; then
    profile="$2"
  fi

  shares=$(get_config "$profile" "shares")

  if [ -z "$shares" ]; then
    echo "❌ No shares defined in profile '$profile'"
    return 1
  fi

  IFS=',' read -ra list <<< "$shares"

  for s in "${list[@]}"; do
    mount_nas "$s" --profile "$profile"
  done
}

# --------------------------
# Config command
# --------------------------
config_profile() {
  read -p "Profile name: " profile
  read -p "Host: " host
  read -p "Username: " user
  read -s -p "Password: " pass
  echo
  read -p "Domain [WORKGROUP]: " domain
  read -p "Shares (comma separated): " shares

  [ -z "$domain" ] && domain="WORKGROUP"

  sed -i "/^\[$profile\]/,/^\[/d" "$CONFIG_FILE"

  cat >> "$CONFIG_FILE" <<EOF
[$profile]
host=$host
user=$user
pass=$pass
domain=$domain
shares=$shares
EOF

  chmod 600 "$CONFIG_FILE"

  echo "✅ Profile saved"
}

# --------------------------
# Entry
# --------------------------
case "$1" in
  all)
    shift
    mount_all "$@"
    ;;
  config)
    config_profile
    ;;
  list)
    list_profiles
    ;;
  *)
    mount_nas "$@"
    ;;
esac